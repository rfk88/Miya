// Copy this file to Secrets.xcconfig and replace placeholders with real values.
// Do NOT commit Secrets.xcconfig. It is in .gitignore.
// Get ROOK keys from your ROOK dashboard; get Supabase URL and anon key from Supabase project Settings → API.

INFOPLIST_KEY_RookClientUUID = YOUR_ROOK_CLIENT_UUID
INFOPLIST_KEY_RookSecretKey = YOUR_ROOK_SECRET_KEY
INFOPLIST_KEY_SupabaseURL = https://YOUR_PROJECT_REF.supabase.co
INFOPLIST_KEY_SupabaseAnonKey = YOUR_SUPABASE_ANON_KEY
